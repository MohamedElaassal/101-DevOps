N8N_HOST=localhost
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=UTC

# Protect n8n UI in local mode
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_now

# Variable used by the imported workflow
# Put a Slack/Discord/Teams incoming webhook URL here
N8N_NOTIFY_WEBHOOK_URL=https://example.com/notify-webhook
